{
    "version": "1.0",
    "sensorTypes": {
        "seepage": {
            "name": "渗流",
            "escalationRules": {
                "warning": {
                    "nextLevel": "critical",
                    "condition": "duration",
                    "threshold": 1800000,
                    "label": "30分钟"
                },
                "critical": {
                    "nextLevel": "emergency",
                    "condition": "duration",
                    "threshold": 900000,
                    "rename": "溃坝预警",
                    "label": "15分钟"
                }
            }
        },
        "displacement": {
            "name": "位移",
            "escalationRules": {
                "warning": {
                    "nextLevel": "critical",
                    "condition": "duration",
                    "threshold": 1200000,
                    "label": "20分钟"
                },
                "critical": {
                    "nextLevel": "emergency",
                    "condition": "rate",
                    "threshold": 2.0,
                    "label": "速率>2.0mm/天"
                }
            }
        },
        "water_level": {
            "name": "水位",
            "escalationRules": {
                "warning": {
                    "nextLevel": "critical",
                    "condition": "value",
                    "threshold": 148.0,
                    "label": "水位>148m"
                },
                "critical": {
                    "nextLevel": "emergency",
                    "condition": "value",
                    "threshold": 150.0,
                    "label": "水位>150m"
                }
            }
        },
        "crack": {
            "name": "裂缝",
            "escalationRules": {
                "warning": {
                    "nextLevel": "critical",
                    "condition": "duration",
                    "threshold": 3600000,
                    "label": "60分钟"
                },
                "critical": {
                    "nextLevel": "emergency",
                    "condition": "rate",
                    "threshold": 1.0,
                    "label": "扩展速率>1.0mm/天"
                }
            }
        },
        "stress": {
            "name": "应力",
            "escalationRules": {
                "warning": {
                    "nextLevel": "critical",
                    "condition": "duration",
                    "threshold": 1800000,
                    "label": "30分钟"
                },
                "critical": {
                    "nextLevel": "emergency",
                    "condition": "value",
                    "threshold": 5.0,
                    "label": "应力>5.0MPa"
                }
            }
        }
    },
    "convergence": {
        "radius": 100,
        "timeWindow": 300000,
        "minAlerts": 3,
        "convergedLevel": "critical"
    },
    "stateTransitions": {
        "active": {
            "acknowledge": "acknowledged",
            "escalate": "escalated",
            "resolve": "resolved",
            "auto_escalate": "escalated"
        },
        "acknowledged": {
            "escalate": "escalated",
            "resolve": "resolved",
            "auto_escalate": "escalated"
        },
        "escalated": {
            "acknowledge": "acknowledged",
            "resolve": "resolved",
            "auto_escalate": "escalated"
        },
        "resolved": {
            "reactivate": "active"
        }
    },
    "levelOrder": ["info", "warning", "critical", "emergency"]
}
